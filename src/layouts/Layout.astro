---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'FenixGate — Fabrica de Software',
  description = 'FenixGate, fábrica de software ecuatoriana. Software escalable a medida, bots con IA, automatizaciones y más.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="icon" type="image/png" href="/Logos/logo solo.png" />
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@400;600;700&family=Inter:wght@300;400;500&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@400;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" /></noscript>
</head>
<body>
  <div id="main-content">
    <slot />
  </div>
</body>
</html>
